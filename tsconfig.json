{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "outDir":           "dist",
    "rootDir":          "src",
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "esModuleInterop":  true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
